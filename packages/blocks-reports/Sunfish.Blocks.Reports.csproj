<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.Reports</PackageId>
    <Description>Read-side report cartridge cluster. Substrate for IReportCartridge&lt;TParams, TResult&gt; + IReportRunner + ReportCartridgeRegistry per Stage 02 §6.1. Cartridges (Trial Balance, AR/AP Aging, P&amp;L by Property, Rent Roll) ship as additive PRs in subsequent hand-offs.</Description>
    <PackageTags>reports;read-side;cartridge;trial-balance;ar-aging;ap-aging;rent-roll;blocks;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.Reports.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <!-- W#72 PR 2 — Trial Balance cartridge consumes ledger + periods read surfaces. -->
    <ProjectReference Include="..\blocks-financial-ledger\Sunfish.Blocks.FinancialLedger.csproj" />
    <ProjectReference Include="..\blocks-financial-periods\Sunfish.Blocks.FinancialPeriods.csproj" />
    <!-- W#72 PR 3 — AR Aging Summary cartridge consumes AR aging + party read surfaces. -->
    <ProjectReference Include="..\blocks-financial-ar\Sunfish.Blocks.FinancialAr.csproj" />
    <ProjectReference Include="..\blocks-people-foundation\Sunfish.Blocks.People.Foundation.csproj" />
    <!-- W#72 PR 6 — Rent Roll v2 cartridge consumes lease service for unit + tenant data. -->
    <ProjectReference Include="..\blocks-leases\Sunfish.Blocks.Leases.csproj" />
  </ItemGroup>
</Project>
