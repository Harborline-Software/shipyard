<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.FinancialPeriods</PackageId>
    <Description>FiscalYear + FiscalPeriod entities + period-close machinery for the Sunfish Anchor native financial domain. Foundational; consumed by blocks-financial-ledger's posting algorithm for period-gating.</Description>
    <PackageTags>fiscal-year;fiscal-period;period-close;retained-earnings;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.FinancialPeriods.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-events\Sunfish.Foundation.Events.csproj" />
    <ProjectReference Include="..\foundation-import\Sunfish.Foundation.Import.csproj" />
    <ProjectReference Include="..\blocks-financial-ledger\Sunfish.Blocks.FinancialLedger.csproj" />
  </ItemGroup>
</Project>
