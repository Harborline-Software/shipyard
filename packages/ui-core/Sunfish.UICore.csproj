<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.UICore</PackageId>
    <Description>Framework-agnostic CSS, icon, and JS interop contracts for Sunfish.</Description>
    <!-- TODO(SUNFISH_I18N_002): Path A temporary suppression. ui-core's SharedResource bundle
         (default + ar-SA) defines 8 cascade keys that aren't yet consumed by any .cs / .razor
         in this package — scaffolded ahead of consumer wiring. Remove this suppression once
         consumers wire the keys via IStringLocalizer indexer or GetString. Follow-up: wire
         ui-core SharedResource consumers. -->
    <NoWarn>CS1591;SUNFISH_I18N_002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.UICore.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <!-- W#53 P1a (ADR 0066): Wayfinder Helm + Atlas substrate.
         NOTE: kernel-runtime is intentionally NOT referenced here —
         packages/kernel-runtime already references packages/ui-core
         (line 23 of its csproj), so a ui-core → kernel-runtime
         ProjectReference would form a circular dependency. The hand-off
         cited `Sunfish.Kernel.Runtime.Teams.TeamId` for HelmRenderContext;
         the Phase 1a substrate substitutes `Guid?` so the active-team
         identifier round-trips without the type wrapper crossing the
         cycle. Consumers in kernel-runtime / accelerators wrap the Guid
         back into TeamId at the boundary. -->
    <ProjectReference Include="..\foundation-ui-syncstate\Sunfish.Foundation.UI.SyncState.csproj" />
    <ProjectReference Include="..\foundation-mission-space\Sunfish.Foundation.MissionSpace.csproj" />
    <!-- W#53 P1b: KeyFingerprint lives in foundation/Crypto/ alongside
         PrincipalId. The hand-off cited foundation-recovery, but
         foundation-recovery → kernel-security (existing) → ui-core
         (existing) forms a cycle that prevents ui-core from referencing
         foundation-recovery. KeyFingerprint is a tiny crypto value type
         with no recovery-specific dependencies, so the foundation/Crypto/
         placement is architecturally clean (sibling to PrincipalId) and
         cycle-safe. -->
    <!-- foundation already referenced above; no additional reference
         needed for KeyFingerprint. -->
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
</Project>
