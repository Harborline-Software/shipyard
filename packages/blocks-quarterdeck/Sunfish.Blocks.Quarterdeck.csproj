<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.Quarterdeck</PackageId>
    <RootNamespace>Sunfish.Blocks.Quarterdeck</RootNamespace>
    <Description>Block-tier Blazor UI components for the Quarterdeck entry-point surface (ADR 0080): WatchStatusPanel (OOD-role watch display + watch-handover alertdialog), AlertTickerPanel (two-politeness live-region alert ticker + pause), and KpiCardGrid (accessible department KPI cards). Phase 3a read-only panels. Per W#51 Phase 3a.</Description>
    <PackageTags>sunfish;blocks;quarterdeck;adr-0080;blazor</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-quarterdeck\Sunfish.Foundation.Quarterdeck.csproj" />
    <ProjectReference Include="..\foundation-ship-common\Sunfish.Foundation.Ship.Common.csproj" />
    <ProjectReference Include="..\foundation-wayfinder\Sunfish.Foundation.Wayfinder.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.Quarterdeck.Tests" />
  </ItemGroup>
</Project>
