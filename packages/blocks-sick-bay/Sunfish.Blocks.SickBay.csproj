<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.SickBay</PackageId>
    <RootNamespace>Sunfish.Blocks.SickBay</RootNamespace>
    <Description>Block-tier reference implementations for the Sick Bay aggregation surface (ADR 0082): SickBayDataProvider (k=3-anonymized pharmacy + Mission Envelope projections), DefaultStretcherBearerPolicy, DefaultFirstAidSurface, and NoopKeyRotationScheduler (Phase 2). Phase 3a: Blazor UI — SickBayBlock tab navigation + PharmacyTabContent / LabTabContent / AtmosphereTabContent / MedevacDialog / KeyFingerprintDisplay per ADR 0082 §8. Critical invariant (H4): NO IFieldDecryptor reference.</Description>
    <PackageTags>sunfish;blocks;sick-bay;adr-0082</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-mission-space\Sunfish.Foundation.MissionSpace.csproj" />
    <ProjectReference Include="..\foundation-ship-common\Sunfish.Foundation.Ship.Common.csproj" />
    <ProjectReference Include="..\foundation-sick-bay\Sunfish.Foundation.SickBay.csproj" />
    <ProjectReference Include="..\kernel-audit\Sunfish.Kernel.Audit.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.SickBay.Tests" />
  </ItemGroup>
</Project>
