<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.Session</PackageId>
    <RootNamespace>Sunfish.Foundation.Session</RootNamespace>
    <Description>First-party session-establishment substrate (ADR 0099). Tier-1 domain-block: the single ISessionEstablisher session-create seam (password login + verify-email completion + magic-link consume all route through EstablishAsync), a server-side opaque-id ISessionStore (InMemorySessionStore v1; SQLite/Postgres in a later PR), the SessionRecord, and the AddSunfishSessionEstablishment DI extension. Holds abstractions + in-memory impl only; references foundation (TenantId) + the ASP.NET Core shared framework (HttpContext + SignInAsync) but NOT foundation-authorization — acyclic ProjectRef direction per ADR 0099 O-7/A8 keeps the substrate reusable by a future BYO-OIDC scheme package and avoids the ADR-0091 circular-ref trap. SessionBackedTenantContext + the AuthEndpoints route live in Bridge, not here.</Description>
    <PackageTags>sunfish;foundation;session;authentication;cookie;bff;adr-0099</PackageTags>
    <!-- NU1510 suppressed: direct PackageReference for
         Microsoft.Extensions.DependencyInjection.Abstractions (IServiceCollection,
         ServiceLifetime) + Microsoft.Extensions.Options (IOptions, OptionsBuilder)
         are required but NuGet preview.4 pruning flags them as unnecessary due to
         transitive availability via the Microsoft.AspNetCore.App framework
         reference. Per fleet-conventions §"NU1510 — keep the PackageRef, suppress
         the warning" + the LANDED foundation-authorization csproj precedent
         (ADR 0099 A4); reference template shipyard commit b4475df.
         CS1591 suppressed for the AuditEventTypes constant strings (self-describing
         names; xmldoc on the container type). -->
    <NoWarn>$(NoWarn);CS1591;NU1510</NoWarn>
  </PropertyGroup>
  <!-- HttpContext (Http.Abstractions) + SignInAsync (Authentication.Abstractions) +
       CookieAuthenticationDefaults come from the ASP.NET Core shared framework. ADR 0099
       O-7 names "Http.Abstractions + Authentication.Abstractions"; the shared-framework
       reference is the canonical ASP.NET Core 3.0+ way to surface those abstractions
       (the standalone Microsoft.AspNetCore.Http.Abstractions v2.x packages are legacy).
       Mirrors every packages/blocks-* csproj that touches HttpContext. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <!-- ADR 0099 O-7/A8: foundation (TenantId) ONLY. Explicitly NOT
         foundation-authorization — the establisher takes UserId/TenantId primitives,
         not the facade. Acyclic: foundation <- foundation-authorization;
         foundation <- foundation-session; Bridge <- both. -->
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.Session.Tests" />
  </ItemGroup>
</Project>
