@* Read-display inspection list. Consumes IReviewsService via DI.
   Template editor, response capture, deficiency detail, and mobile capture are deferred. *@

@inject IReviewsService ReviewsService

@if (_inspections is null)
{
    <div class="sf-inspection-list__loading">Loading inspections…</div>
}
else if (_inspections.Count == 0)
{
    <div class="sf-inspection-list__empty">No inspections scheduled</div>
}
else
{
    <table class="sf-inspection-list">
        <thead>
            <tr>
                <th class="sf-inspection-list__col-date">Scheduled date</th>
                <th class="sf-inspection-list__col-unit">Unit</th>
                <th class="sf-inspection-list__col-phase">Phase</th>
                <th class="sf-inspection-list__col-inspector">Inspector</th>
                <th class="sf-inspection-list__col-deficiencies">Deficiencies</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _inspections)
            {
                <tr class="sf-inspection-list__row" data-inspection-id="@row.Review.Id">
                    <td class="sf-inspection-list__col-date">@row.Review.ScheduledDate.ToString("yyyy-MM-dd")</td>
                    <td class="sf-inspection-list__col-unit">@row.Review.UnitId</td>
                    <td class="sf-inspection-list__col-phase">@row.Review.Phase</td>
                    <td class="sf-inspection-list__col-inspector">@row.Review.InspectorName</td>
                    <td class="sf-inspection-list__col-deficiencies">@row.DeficiencyCount</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ReviewRow>? _inspections;

    private sealed record ReviewRow(Review Review, int DeficiencyCount);

    /// <summary>
    /// Optional filter to pass when loading inspections. Defaults to <see cref="ListReviewsQuery.Empty"/>
    /// (returns all inspections).
    /// </summary>
    [Parameter] public ListReviewsQuery Query { get; set; } = ListReviewsQuery.Empty;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rows = new List<ReviewRow>();
            await foreach (var inspection in ReviewsService.ListReviewsAsync(Query))
            {
                var defCount = 0;
                await foreach (var _ in ReviewsService.ListDeficienciesAsync(inspection.Id))
                    defCount++;

                rows.Add(new ReviewRow(inspection, defCount));
            }
            _inspections = rows;
        }
        catch
        {
            _inspections = [];
        }
    }
}
