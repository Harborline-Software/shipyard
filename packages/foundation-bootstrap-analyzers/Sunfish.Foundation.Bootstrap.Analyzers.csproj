<!--
    Roslyn analyzer for ADR 0095 Step 3 (BootstrapAndTenantMutualExclusionAnalyzer).
    Sibling csproj per the foundation-wayfinder-analyzers precedent: targets
    netstandard2.0 (Roslyn analyzer contract); ships into NuGet analyzers/dotnet/cs.

    Two diagnostics:
      * SUNFISH_BOOTSTRAP001 — constructor injects both IBootstrapContext and
        a post-tenant context interface (mutual-exclusion violation; closes
        the confused-deputy seam at compile time).
      * SUNFISH_BOOTSTRAP002 — endpoint registered inside MapBootstrapEndpoints
        whose fluent chain does NOT include .AllowAnonymous() (Rev 2 / sec-eng
        Gap D — prevents pre-auth-by-omission).
-->
<Project Sdk="Microsoft.NET.Sdk">

  <!-- Opt out of Central Package Management; analyzer needs Microsoft.CodeAnalysis.* not in repo-wide pins. -->
  <PropertyGroup>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <PropertyGroup>
    <!--
      The Directory.Build.props BannedApiAnalyzers auto-attach predicate
      excludes any project ending in `.Analyzers`, so this project falls
      outside the auto-attach automatically — no local opt-out needed.
    -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <IsRoslynComponent>true</IsRoslynComponent>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.Bootstrap.Analyzers</PackageId>
    <Description>Roslyn analyzer that emits SUNFISH_BOOTSTRAP001 (constructor injects both IBootstrapContext and a post-tenant context interface) and SUNFISH_BOOTSTRAP002 (MapBootstrapEndpoints-registered endpoint without .AllowAnonymous()). Per ADR 0095 Step 3.</Description>
    <PackageTags>roslyn;analyzer;sunfish;bootstrap;adr-0095</PackageTags>
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <RootNamespace>Sunfish.Foundation.Bootstrap.Analyzers</RootNamespace>
    <AssemblyName>Sunfish.Foundation.Bootstrap.Analyzers</AssemblyName>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="README.md" Pack="true" PackagePath="\" Condition="Exists('README.md')" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.8.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.Bootstrap.Analyzers.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
    <None Remove="tests/**/*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Roslyn analyzer release-tracking files satisfy the RS2008 check. -->
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
</Project>
