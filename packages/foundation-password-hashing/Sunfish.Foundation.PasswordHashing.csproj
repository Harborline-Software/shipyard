<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.PasswordHashing</PackageId>
    <RootNamespace>Sunfish.Foundation.PasswordHashing</RootNamespace>
    <Description>Tier-1 PasswordHasher substrate (ADR 0097). Argon2id-via-Konscious IPasswordHasher&lt;TUser&gt; concrete (PHC-string wire format; legacy ASP.NET Identity V3 PBKDF2 verify fallback with SuccessRehashNeeded migration trigger; below-floor-parameter rehash trigger), a constant-string MockPasswordHasher&lt;TUser&gt; carrying the IMockPasswordHasher marker, the Argon2idParameterFloorAssertion + MockPasswordHasherProductionGuardAssertion startup IHostedServices, the Argon2idHashOptions + Argon2idHashOptionsValidator floor enforcement, and the AddSunfishPasswordHashingSubstrate / AddSunfishPasswordHashing&lt;TUser&gt; / AddSunfishMockPasswordHashing&lt;TUser&gt; DI helpers. Concrete DI, no vendor swap (Argon2id is a primitive, not a vendor surface). References Microsoft.Extensions.Identity.Core for the BCL IPasswordHasher&lt;TUser&gt; interface; acyclic — no foundation-* ProjectReference.</Description>
    <PackageTags>sunfish;foundation;password-hashing;argon2id;cryptography;authentication;adr-0097</PackageTags>
    <!-- S4 sec-eng substrate amendment: supply-chain integrity floor. The
         Konscious cryptographic-primitive dependency is pinned via packages.lock.json
         + RestoreLockedMode so substrate-tier dependency bumps require an explicit
         ADR amendment, not a silent `dotnet restore` regeneration. ADR 0097 is the
         substrate that establishes this floor for cryptographic-primitive substrates. -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <RestoreLockedMode Condition="'$(ContinuousIntegrationBuild)' == 'true'">true</RestoreLockedMode>
    <!-- NU1510 suppressed: direct PackageReferences for
         Microsoft.Extensions.DependencyInjection.Abstractions (IServiceCollection,
         ServiceDescriptor, ServiceLifetime, TryAddEnumerable),
         Microsoft.Extensions.Hosting.Abstractions (IHostedService), and
         Microsoft.Extensions.Options (IOptions, IValidateOptions, OptionsBuilder)
         are required but NuGet preview.4 pruning flags them as unnecessary due to
         transitive availability via Microsoft.Extensions.Identity.Core. Per
         fleet-conventions §"NU1510 — keep the PackageRef, suppress the warning" +
         the LANDED foundation-authorization / foundation-session csproj precedents;
         reference template shipyard commit b4475df. -->
    <NoWarn>$(NoWarn);CS1591;NU1510</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- ADR 0097 Q7 RESOLVED — 5 PackageReferences minimal. -->
    <!-- BCL IPasswordHasher<TUser> + PasswordVerificationResult enum + the BCL
         PasswordHasher<TUser> default impl (legacy-V3 PBKDF2 verify fallback).
         These types live in Microsoft.Extensions.Identity.Core (namespace
         Microsoft.AspNetCore.Identity); see ADR 0097 A2 deviation note in
         Directory.Packages.props. -->
    <PackageReference Include="Microsoft.Extensions.Identity.Core" />
    <!-- Argon2id primitive (Halt 2; v1.3.1 band; CPM-pinned). -->
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" />
    <!-- IServiceCollection / ServiceDescriptor / services.Replace / TryAddEnumerable. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <!-- IHostedService (the floor + production-guard startup assertions). -->
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <!-- IOptions<Argon2idHashOptions> + IValidateOptions<T> + OptionsBuilder. -->
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.PasswordHashing.Tests" />
  </ItemGroup>
</Project>
