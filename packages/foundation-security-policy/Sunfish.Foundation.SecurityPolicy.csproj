<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Sunfish.Foundation.SecurityPolicy</RootNamespace>
    <AssemblyName>Sunfish.Foundation.SecurityPolicy</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.SecurityPolicy</PackageId>
    <Description>Tenant-configurable security policy substrate per ADR 0068 (MFA, device attestation, audit retention, key rotation, recovery contact). PR 1: data-model records + enums. Validation pipeline + audit event types ship in subsequent PRs.</Description>
    <PackageTags>security;policy;mfa;attestation;retention;tenant;sunfish;foundation</PackageTags>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.SecurityPolicy.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-ship-common\Sunfish.Foundation.Ship.Common.csproj" />
    <!-- PR 3b.1 — ApprovalChain / ApprovalStep / StandingOrder (ADR 0065 §1). -->
    <ProjectReference Include="..\foundation-wayfinder\Sunfish.Foundation.Wayfinder.csproj" />
    <!-- PR 3b.2 — IAuditRetentionEnforcer contract for DefaultAuditRetentionEnforcer. -->
    <ProjectReference Include="..\kernel-audit\Sunfish.Kernel.Audit.csproj" />
  </ItemGroup>
</Project>
