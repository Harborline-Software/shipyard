<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.Assets</PackageId>
    <Description>Asset-management block for Sunfish — the property-agnostic asset domain (Asset, AssetCategory, AssetLifecycleEvent, DepreciationSchedule, WarrantyTerm, tenant-scoped repositories) per ADR 0101 C1.1, alongside the read-display file-catalog AssetCatalogBlock surface.</Description>
    <PackageTags>blazor;assets;asset-management;lifecycle;depreciation;warranty;catalog;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- TODO(SUNFISH_I18N_002): Path A temporary suppression — SharedResource scaffolded
         ahead of consumer wiring. Remove once IStringLocalizer references land. -->
    <NoWarn>CS1591;SUNFISH_I18N_002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.Assets.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <!-- ADR 0101 C1.1: asset domain is IMustHaveTenant (foundation-multitenancy) with a
         Money cost basis (foundation-integrations). NO reference on blocks-property-equipment
         (D3 — property-coupling forbidden on a property-agnostic block). -->
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-integrations\Sunfish.Foundation.Integrations.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
</Project>
