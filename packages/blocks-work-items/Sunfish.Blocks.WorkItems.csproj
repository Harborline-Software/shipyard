<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.WorkItems</PackageId>
    <!-- Major bump (0.1.0 inherited default -> 1.0.0): renamed from Sunfish.Blocks.WorkOrders
         per ADR 0098. Binary-compat-survivable via the blocks-work-orders re-export shim, but
         AssemblyName changes, so a major bump is the honest SemVer signal. -->
    <Version>1.0.0</Version>
    <Description>WorkItem + MaintenanceSchedule + Contractor entities for the Sunfish work-cluster domain (renamed from Sunfish.Blocks.WorkOrders per ADR 0098 block-naming generalization). Day-to-day repair tickets, preventive maintenance, contractor assignments, and deficiency hand-offs from blocks-property-*. Distinct from blocks-workflow (state-machine engine).</Description>
    <PackageTags>work-item;maintenance;contractor;repair-ticket;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.WorkItems.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
</Project>
