<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.EngineRoom</PackageId>
    <RootNamespace>Sunfish.Blocks.EngineRoom</RootNamespace>
    <Description>Block-tier reference implementations for the Engine Room observability surface (ADR 0079): DefaultEngineRoomDataProvider with optional ISyncDaemonHealthSource + ICrdtDocumentRegistry seams, EngineRoomOptions for heartbeat-interval tuning, the SubscribeHealthAsync dedup pattern, DefaultEngineRoomCommandService with IPermissionResolver + EOOW watch advisory + §Trust audit-emission ordering, Phase 3a read-only Blazor panels (EngineRoomHealthBanner, MainPropulsionPanel, ElectricalPanel), and Phase 3b command surface (DamageControlPanel with alertdialog + deliberation-pause, QaWorkshopPanel stub). Per W#50 Phase 2a + 2b + 3a + 3b.</Description>
    <PackageTags>sunfish;blocks;engine-room;adr-0079;blazor</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-engine-room\Sunfish.Foundation.EngineRoom.csproj" />
    <ProjectReference Include="..\foundation-ship-common\Sunfish.Foundation.Ship.Common.csproj" />
    <ProjectReference Include="..\foundation-wayfinder\Sunfish.Foundation.Wayfinder.csproj" />
    <ProjectReference Include="..\kernel-audit\Sunfish.Kernel.Audit.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.EngineRoom.Tests" />
  </ItemGroup>
</Project>
