@* EngineRoomHealthBanner — Engine Room observability surface (ADR 0079 §2, W#50 Phase 3a).
   Displays aggregate subsystem health + EOOW badge. Two sibling aria-live regions per §6:
   assertive for degradation transitions, polite for heartbeat updates. Live regions are
   always in DOM (ARIA22/SC 4.1.3) — hoisted above all conditional branches. Permission gate:
   ShipAction.ViewEngineRoom must be verified before the provider is called. *@

@implements IDisposable

<div class="er-health-banner" role="region" aria-label="Engine Room health">

    @* Live regions always in DOM — content injected into pre-existing regions so AT
       observes changes. Never rendered for the first time with content (ARIA22/SC 4.1.3). *@
    <div role="alert" aria-live="assertive" aria-atomic="true"
         class="er-live-assertive sf-sr-only">
        @_assertiveAnnouncement
    </div>
    <div role="status" aria-live="polite" aria-atomic="false"
         class="er-live-polite sf-sr-only">
        @_politeAnnouncement
    </div>

    @if (_permissionDenied)
    {
        <p role="alert">You do not have permission to view the Engine Room.</p>
    }
    else if (_summary is null)
    {
        <p role="status" aria-busy="true">Loading Engine Room status…</p>
    }
    else
    {
        @* EOOW badge — icon is decorative; visible text is the accessible name (SC 2.5.3).
           Abbreviation "EOOW" expanded via <abbr> title per HTML spec. *@
        <div class="er-eoow-badge">
            @if (_eoowWatch is null)
            {
                <span aria-hidden="true">⚓</span>
                <span>No EOOW on watch</span>
            }
            else
            {
                <span aria-hidden="true">🛳</span>
                <span>
                    <abbr title="Engineering Officer of the Watch">EOOW</abbr>:
                    @_eoowWatch.OnWatchActor
                </span>
            }
        </div>

        @* Subsystem status tiles — severity conveyed via text label; icon is decorative (SC 1.4.1).
           aria-hidden="true" on icon: adjacent visible status text provides the information. *@
        <ul class="er-subsystem-list" aria-label="Subsystem statuses">
            @foreach (var entry in _summary.SubsystemHealthList)
            {
                var statusCss = StatusCssClass(entry.Status);
                var statusLabel = StatusLabel(entry.Status);
                <li class="er-subsystem-tile @statusCss">
                    <span class="er-subsystem-icon" aria-hidden="true">
                        @StatusIcon(entry.Status)
                    </span>
                    <span class="er-subsystem-name">@SubsystemLabel(entry.Subsystem)</span>
                    <span class="er-subsystem-status">@statusLabel</span>
                    @if (entry.Message is { } msg)
                    {
                        <span class="er-subsystem-message">@msg</span>
                    }
                </li>
            }
        </ul>
    }

</div>

@code {
    [Parameter, EditorRequired] public TenantId Tenant { get; set; }
    [Parameter, EditorRequired] public ActorId Actor { get; set; }

    [Inject] private IEngineRoomDataProvider DataProvider { get; set; } = default!;
    [Inject] private IOodWatchService WatchService { get; set; } = default!;
    [Inject] private IPermissionResolver PermissionResolver { get; set; } = default!;
    [Inject] private IActorPrincipalResolver ActorPrincipalResolver { get; set; } = default!;

    private EngineRoomHealthSummary? _summary;
    private OodWatch? _eoowWatch;
    private bool _permissionDenied;
    private string? _assertiveAnnouncement;
    private string? _politeAnnouncement;
    private SubsystemStatus? _previousWorstStatus;
    private CancellationTokenSource _cts = new();

    protected override async Task OnParametersSetAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        _permissionDenied = false;
        _summary = null;

        var principal = await ActorPrincipalResolver.ResolveAsync(Tenant, Actor);
        if (principal is null)
        {
            _permissionDenied = true;
            return;
        }

        var decision = await PermissionResolver.ResolveAsync(
            Tenant, principal, ShipLocation.EngineRoom, DeckDepth.MainDeck,
            ShipAction.ViewEngineRoom, resource: null);

        if (decision is PermissionDecision.Denied)
        {
            _permissionDenied = true;
            return;
        }

        await RefreshAsync(_cts.Token);
    }

    private async Task RefreshAsync(CancellationToken ct)
    {
        _assertiveAnnouncement = null;
        _politeAnnouncement    = null;

        var summary = await DataProvider.GetHealthSummaryAsync(Tenant, ct);
        var eoow = await WatchService.GetActiveWatchAsync(
            Tenant, OodRole.EngineeringOfficerOfTheWatch);

        var worstNow = WorstStatus(summary);
        var rankNow  = SeverityRank(worstNow);
        var rankPrev = _previousWorstStatus.HasValue ? SeverityRank(_previousWorstStatus.Value) : -1;

        if (rankNow > 0 && rankNow > rankPrev)
            _assertiveAnnouncement = $"Engine Room status degraded: {StatusLabel(worstNow)}.";
        else
            _politeAnnouncement = $"Engine Room health updated: {StatusLabel(worstNow)}.";

        _previousWorstStatus = worstNow;
        _summary = summary;
        _eoowWatch = eoow;
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    // Unknown is semantically "not yet known" — not a degraded state; rank -1 keeps it
    // out of the degradation check and lets .OrderByDescending pick the actual worst status.
    private static int SeverityRank(SubsystemStatus s) => s switch
    {
        SubsystemStatus.Operational => 0,
        SubsystemStatus.Warning     => 1,
        SubsystemStatus.Critical    => 2,
        _                           => -1,
    };

    private static SubsystemStatus WorstStatus(EngineRoomHealthSummary summary)
    {
        if (summary.SubsystemHealthList.Count == 0)
            return SubsystemStatus.Unknown;
        return summary.SubsystemHealthList
            .OrderByDescending(h => SeverityRank(h.Status))
            .Select(h => h.Status)
            .First();
    }

    private static string StatusCssClass(SubsystemStatus status) => status switch
    {
        SubsystemStatus.Operational => "er-status--operational",
        SubsystemStatus.Warning     => "er-status--warning",
        SubsystemStatus.Critical    => "er-status--critical",
        _                           => "er-status--unknown",
    };

    private static string StatusLabel(SubsystemStatus status) => status switch
    {
        SubsystemStatus.Operational => "Operational",
        SubsystemStatus.Warning     => "Warning",
        SubsystemStatus.Critical    => "Critical",
        _                           => "Unknown",
    };

    private static string StatusIcon(SubsystemStatus status) => status switch
    {
        SubsystemStatus.Operational => "✓",
        SubsystemStatus.Warning     => "!",
        SubsystemStatus.Critical    => "✗",
        _                           => "?",
    };

    private static string SubsystemLabel(EngineRoomSubsystem subsystem) => subsystem switch
    {
        EngineRoomSubsystem.MainPropulsion => "Main Propulsion",
        EngineRoomSubsystem.Electrical     => "Electrical",
        EngineRoomSubsystem.DamageControl  => "Damage Control",
        EngineRoomSubsystem.QaWorkshop     => "QA Workshop",
        _                                   => subsystem.ToString(),
    };
}
