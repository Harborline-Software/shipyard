<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.ShipsOffice</PackageId>
    <RootNamespace>Sunfish.Blocks.ShipsOffice</RootNamespace>
    <Description>Block-tier substrate for the Ship's Office aggregation surface (ADR 0083): Phase 2 data + command + diff services + Phase 3 Blazor UI (ShipsOfficeBlock + 4 sub-components). Critical invariant: NO IFieldDecryptor reference anywhere (W9 TIN field excluded from the browse view by design).</Description>
    <PackageTags>sunfish;blocks;ships-office;adr-0083;blazor</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\blocks-leases\Sunfish.Blocks.Leases.csproj" />
    <ProjectReference Include="..\blocks-maintenance\Sunfish.Blocks.Maintenance.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-catalog\Sunfish.Foundation.Catalog.csproj" />
    <ProjectReference Include="..\foundation-mission-space\Sunfish.Foundation.MissionSpace.csproj" />
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-ship-common\Sunfish.Foundation.Ship.Common.csproj" />
    <ProjectReference Include="..\foundation-ships-office\Sunfish.Foundation.ShipsOffice.csproj" />
    <ProjectReference Include="..\kernel-audit\Sunfish.Kernel.Audit.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.ShipsOffice.Tests" />
  </ItemGroup>
</Project>
