<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.Integrations</PackageId>
    <Description>Runtime contracts for external provider integrations: provider registry, credentials references, webhook event envelopes + dispatcher, sync cursors, health checks. ADR 0096 Step 1 extends with the Tier-2 vendor-provider substrate (IMockVendorProvider marker + IMockVendorEnvVarRegistry + MockProviderProductionGuardAssertion IHostedService + IEmailProvider/MockEmailProvider). See ADR 0013 + ADR 0096.</Description>
    <PackageTags>sunfish;foundation;integrations;webhooks;providers;tier-2-vendor-substrate</PackageTags>
    <!-- NU1510 suppressed: direct PackageReferences for
         Microsoft.Extensions.DependencyInjection.Abstractions,
         Microsoft.Extensions.Hosting.Abstractions, and
         Microsoft.Extensions.Logging.Abstractions are required by ADR 0096
         Step 1 substrate (IServiceCollection, ServiceDescriptor,
         services.Replace, IHostedService, ILogger<T>) but NuGet preview.4
         pruning flags them as unnecessary due to transitive availability
         via Microsoft.Extensions.DependencyInjection. Per fleet-conventions
         §"NU1510 — keep the PackageRef, suppress the warning"; reference
         template shipyard commit b4475df. -->
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-catalog\Sunfish.Foundation.Catalog.csproj" />
    <ProjectReference Include="..\foundation-recovery\Sunfish.Foundation.Recovery.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.Integrations.Tests" />
  </ItemGroup>
</Project>
