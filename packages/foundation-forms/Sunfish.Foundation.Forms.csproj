<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.Forms</PackageId>
    <RootNamespace>Sunfish.Foundation.Forms</RootNamespace>
    <Description>Foundation-tier dynamic forms substrate keystone (ADR 0055). Hosts the canonical FormDefinition record + SunfishOverlay (FieldOverlay / FormSection / SectionAccess / RuleDefinition) + IFormDefinitionStore CRUD/lifecycle facade with an in-memory reference implementation. Scope is type-surface only: JSONB entity persistence (foundation-assets-postgres extension), the IFormEngine rendering surface, the three-tier rule evaluator, and the 20-primitive compound catalog (Sunfish.Foundation.Compounds) ship as separate companion packages composing this keystone.</Description>
    <PackageTags>sunfish;foundation;forms;dynamic-forms;schema;adr-0055</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.Forms.Tests" />
  </ItemGroup>
</Project>
